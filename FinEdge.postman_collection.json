{
  "info": {
    "name": "FinEdge Personal Finance & Expense Tracker API",
    "description": "Postman collection for testing the FinEdge CRUD API endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Utilities",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Register User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.success && response.data && response.data.id) {",
                  "    pm.collectionVariables.set(\"userId\", response.data.id);",
                  "}",
                  "if (response.success && response.token) {",
                  "    pm.collectionVariables.set(\"userToken\", response.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Akash Nair\",\n  \"email\": \"akash@gmail.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Update User Details",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{userToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Akash Nair Updated\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "{{userId}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Delete User Account",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{userToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "{{userId}}"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        {
          "name": "Create Transaction",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.success && response.data && response.data.id) {",
                  "    pm.collectionVariables.set(\"transactionId\", response.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"type\": \"expense\",\n  \"category\": \"Food\",\n  \"amount\": 250,\n  \"description\": \"Lunch\",\n  \"date\": \"2026-06-13\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/transactions",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "transactions"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get All Transactions",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/transactions",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "transactions"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Filtered Transactions",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/transactions?type=expense&category=Food&month=6&year=2026",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "transactions"
              ],
              "query": [
                {
                  "key": "type",
                  "value": "expense"
                },
                {
                  "key": "category",
                  "value": "Food"
                },
                {
                  "key": "month",
                  "value": "6"
                },
                {
                  "key": "year",
                  "value": "2026"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Transaction By ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/transactions/{{transactionId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "transactions",
                "{{transactionId}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Update Transaction",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 300,\n  \"category\": \"Dinner\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/transactions/{{transactionId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "transactions",
                "{{transactionId}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Delete Transaction",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/transactions/{{transactionId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "transactions",
                "{{transactionId}}"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Budgets",
      "item": [
        {
          "name": "Create or Update Budget",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"category\": \"Food\",\n  \"monthlybudget\": 5000\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/budgets",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "budgets"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Summary & Analytics",
      "item": [
        {
          "name": "Get Financial Summary",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/summary",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "summary"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Category-wise Expenses",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/summary/category",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "summary",
                "category"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Monthly Trends",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/summary/monthly",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "summary",
                "monthly"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Top Spending Categories",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/summary/top-categories?limit=3",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "summary",
                "top-categories"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "3"
                }
              ]
            }
          },
          "response": []
        }
      ]
    }
  ],
  "event": [],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "",
      "type": "string"
    },
    {
      "key": "transactionId",
      "value": "",
      "type": "string"
    },
    {
      "key": "userToken",
      "value": "",
      "type": "string"
    }
  ]
}
